{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "policy-pilot",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Run Playbook",
        "description": "Evaluate moderation policy and take action",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/run-playbook"
      },
      {
        "label": "Run Playbook",
        "description": "Evaluate moderation policy and take action",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/run-playbook"
      },
      {
        "label": "Configure Playbooks",
        "description": "Create or manage PolicyPilot playbooks",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/config-playbook"
      },
      {
        "label": "View User History",
        "description": "View moderation history and profile for this user",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/view-history"
      },
      {
        "label": "View User History",
        "description": "View moderation history and profile for this user",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/view-history"
      },
      {
        "label": "Create Dashboard Post",
        "description": "policy-pilot",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Preview Playbook",
        "description": "Simulate a playbook against recent users without taking action",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/preview-playbook"
      },
      {
        "label": "Generate Mod Report",
        "description": "Post a 7-day moderation summary to the subreddit",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mod-report"
      }
    ]
  },
  "forms": {
    "exampleForm": "/internal/form/example-submit",
    "runPlaybookSelect": "/internal/form/run-playbook-evaluate",
    "runPlaybookConfirm": "/internal/form/run-playbook-confirm",
    "configPlaybookSave": "/internal/form/config-playbook-save",
    "viewHistoryDisplay": "/internal/form/view-history-dismiss",
    "viewHistoryDetail": "/internal/form/view-history-detail",
    "previewPlaybookSelect": "/internal/form/preview-playbook-select",
    "previewPlaybookResult": "/internal/form/preview-playbook-result"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onModAction": "/internal/triggers/on-mod-action"
  },
  "scheduler": {
    "tasks": {
      "dashboard-refresh": {
        "endpoint": "/internal/scheduler/dashboard-refresh",
        "cron": "0 * * * *"
      },
      "threshold-check": {
        "endpoint": "/internal/scheduler/threshold-check",
        "cron": "0 * * * *"
      }
    }
  },
  "settings": {
    "subreddit": {
      "autoEscalationEnabled": {
        "type": "boolean",
        "label": "Enable Auto-Escalation Alerts",
        "helpText": "Send a modmail discussion alert when users cross offense thresholds.",
        "defaultValue": true
      },
      "warningsBeforeTempBan": {
        "type": "number",
        "label": "Warnings Before Temp-Ban Alert",
        "helpText": "Number of remove/warn actions within the time window before alerting the mod team. Default: 3.",
        "defaultValue": 3
      },
      "tempBansBeforePermBan": {
        "type": "number",
        "label": "Temp Bans Before Perm-Ban Alert",
        "helpText": "Number of temp bans within the time window before alerting the mod team. Default: 2.",
        "defaultValue": 2
      },
      "timeWindowDays": {
        "type": "number",
        "label": "Alert Time Window (days)",
        "helpText": "How many days back to count offenses when checking thresholds. Default: 30.",
        "defaultValue": 30
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "policy_pilot_dev"
  }
}